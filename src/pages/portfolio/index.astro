---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Blog", href: "/blog" },
  { label: "YouTube", href: "/youtube" },
  { label: "Contact", href: "mailto:prashantchaturvedi2020@gmail.com" },
];

const summary = `AI/ML Engineer with 5+ years of experience building production-grade ML and <span class='hl-ai'>GenAI</span> systems. Skilled in <span class='hl-ai'>LLMs</span>, <span class='hl-ai'>RAG pipelines</span>, <span class='hl-ai'>computer vision</span>, <span class='hl-ai'>conversational AI</span>, and scalable <span class='hl-ai'>ML infrastructure</span>. Proven track record of delivering end-to-end <span class='hl-ai'>AI solutions</span> with <span class='hl-metric'>measurable business impact</span>, real-time deployment, and scalable <span class='hl-tech'>MLOps</span> practices.`;

const experience = [
  {
    role: "Data Scientist II",
    company: "G2 — Bangalore, India",
    period: "Dec 2024 – Present",
    bullets: [
      "Designed a scalable <span class='hl-ai'>RAG pipeline</span> using <span class='hl-tech'>Milvus</span>, implementing embeddings, semantic retrieval, reranking, and optimized chunking strategies for enterprise search.",
      "Built a review moderation platform combining <span class='hl-ai'>ML models</span>, rule engines, and agent workflows, increasing moderation automation from <span class='hl-metric'>30% to 70%</span>.",
      "Developed a <span class='hl-ai'>computer vision</span>-based screenshot validation system to verify real product usage in user-submitted reviews, reducing fraudulent or irrelevant submissions in moderation workflows.",
      "Implemented <span class='hl-ai'>image moderation</span> pipelines using computer vision models and product-aware validation techniques to detect policy violations and improve moderation quality.",
      "Deployed ML services on <span class='hl-tech'>Kubernetes</span> with <span class='hl-tech'>ArgoCD</span> CI/CD pipelines, enabling automated deployments, scalable inference workloads, and reliable production rollouts.",
      "Implemented <span class='hl-tech'>observability</span> pipelines with feature logging, KPI dashboards, and Slack alerts for production monitoring and debugging.",
    ],
  },
  {
    role: "Data Scientist",
    company: "Tiger Analytics — Bangalore, India",
    period: "Mar 2022 – Dec 2024",
    bullets: [
      "Developed a <span class='hl-ai'>conversational AI</span> assistant for pharmaceutical experts, enabling efficient knowledge retrieval and domain-specific question answering.",
      "Built a <span class='hl-ai'>RAG</span> system using <span class='hl-tech'>Qdrant</span>, leveraging embeddings, hybrid retrieval, reranking, and prompt engineering to improve response quality and factual grounding.",
      "Designed <span class='hl-ai'>LLM-powered</span> workflows with context-aware retrieval and structured outputs for enterprise-scale GenAI applications.",
    ],
  },
  {
    role: "Senior Analyst",
    company: "Tiger Analytics — Bangalore, India",
    period: "Mar 2022 – Dec 2024",
    bullets: [
      "Led an end-to-end <span class='hl-ai'>ML pipeline</span> for cancer stage prediction using healthcare claims data.",
      "Applied feature engineering and model selection techniques including Logistic Regression, Random Forest, and <span class='hl-tech'>XGBoost</span>, achieving <span class='hl-metric'>AUC of 85%</span>.",
    ],
  },
  {
    role: "Jr. Data Scientist",
    company: "Tata Consultancy Services — Remote, India",
    period: "Oct 2020 – Mar 2022",
    bullets: [
      "Built an automated <span class='hl-ai'>question generation</span> system using <span class='hl-ai'>NLP</span> and deep learning techniques for educational content creation.",
      "Applied <span class='hl-ai'>POS tagging</span>, embeddings, and fuzzy matching algorithms to improve question quality, diversity, and contextual relevance.",
      "Improved content generation efficiency and reduced manual effort in educational workflows.",
    ],
  },
];

const internships = [
  {
    role: "ML Engineer Intern",
    company: "FreJun Inc — Madhya Pradesh, India",
    period: "Jan 2020 – May 2020",
    bullets: [
      "Worked on <span class='hl-ai'>Natural Language Processing</span> projects including keyword extraction and question extraction from interview call transcripts.",
      "Successfully deployed <span class='hl-ai'>NLP</span> solutions to production on the company website.",
    ],
  },
  {
    role: "ML Engineer Intern",
    company: "Codenscious — Greater Indore Area",
    period: "May 2019 – Jul 2019",
    bullets: [
      "Managed the team under <span class='hl-ai'>vehicle and person detection</span> project, working directly under the CEO.",
      "Interacted with clients and delivered the software with good profit margins.",
      "Worked across different domains including <span class='hl-ai'>time-series</span> analysis and <span class='hl-ai'>reinforcement learning</span>.",
    ],
  },
  {
    role: "ML Engineer Intern",
    company: "Codenscious — Greater Indore Area",
    period: "Jun 2018 – Aug 2018",
    bullets: [
      "Worked on <span class='hl-ai'>diabetes classification</span> project spanning backend, frontend, classical AI, and deep learning.",
      "Gained hands-on experience with advanced ML algorithms such as <span class='hl-ai'>boosting</span> and applied them to real problem sets.",
    ],
  },
];

const skills = [
  { category: "Programming", items: ["Python", "C++", "SQL"] },
  { category: "ML & GenAI", items: ["LLMs", "RAG", "Computer Vision", "NLP", "Deep Learning", "Embeddings", "Semantic Search"] },
  { category: "Frameworks", items: ["PyTorch", "TensorFlow", "Scikit-learn", "FastAPI", "Flask", "LangChain", "HuggingFace"] },
  { category: "Systems", items: ["Milvus", "Qdrant", "FAISS", "PySpark", "REST APIs", "Kubernetes"] },
  { category: "MLOps", items: ["Docker", "ArgoCD", "CI/CD", "Monitoring", "Observability", "Git"] },
  { category: "Cloud", items: ["AWS"] },
];
---

<Layout title="Portfolio — Prashant Chaturvedi">
  <Nav items={navItems} />
  <main class="page">
    <div class="container">
      <h1 class="page-title">Portfolio</h1>
      <p class="page-subtitle">AI/ML Engineer — 5+ years building production-grade ML & GenAI systems</p>

      <section class="section summary-section">
        <p class="summary-text" set:html={summary}></p>
      </section>

      <section class="section">
        <h2 class="section-heading">Experience</h2>
        <div class="timeline">
          {experience.map((e) => (
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-period">{e.period}</span>
                <h3 class="timeline-role">{e.role}</h3>
                <p class="timeline-company">{e.company}</p>
                <ul class="timeline-bullets">
                  {e.bullets.map((b) => <li set:html={b}></li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-heading">Internships</h2>
        <div class="timeline">
          {internships.map((e) => (
            <div class="timeline-item">
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                <span class="timeline-period">{e.period}</span>
                <h3 class="timeline-role">{e.role}</h3>
                <p class="timeline-company">{e.company}</p>
                <ul class="timeline-bullets">
                  {e.bullets.map((b) => <li set:html={b}></li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-heading">Skills</h2>
        <div class="skills-grid">
          {skills.map((s) => (
            <div class="skill-category">
              <h3 class="skill-category-title">{s.category}</h3>
              <div class="skill-tags">
                {s.items.map((t) => <span class="skill-tag">{t}</span>)}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-heading">Education</h2>
        <div class="edu-card">
          <h3>Bachelor of Engineering (B.E.)</h3>
          <p class="edu-meta">Information Technology — Jabalpur Engineering College</p>
          <p class="edu-year">2016 - 2020</p>
        </div>
      </section>

      <section class="section">
        <h2 class="section-heading">Achievements</h2>
        <ul class="achievement-list">
          <li>ACM ICPC Regional Qualifier</li>
          <li>Star of the Quarter and Special Achievement Award</li>
          <li>Filed a patent and published in Applied Clinical Trials</li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .page { padding: 120px 0 40px; }
  .page-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; }
  .page-subtitle { color: var(--slate); font-size: 1.05rem; margin-bottom: 48px; }
  .section { margin-bottom: 56px; }
  .section-heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 24px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--gray-200);
  }

  .summary-section { margin-bottom: 48px; }
  .summary-text {
    font-size: 1rem;
    color: var(--slate);
    line-height: 1.7;
    padding: 20px 24px;
    background: linear-gradient(135deg, var(--gray-50), var(--white));
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    border-left: 4px solid var(--teal);
  }

  .timeline { position: relative; padding-left: 24px; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--gray-200);
  }
  .timeline-item { position: relative; padding-bottom: 36px; }
  .timeline-dot {
    position: absolute;
    left: -20px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--teal);
    border: 2px solid var(--white);
    box-shadow: 0 0 0 2px var(--teal);
  }
  .timeline-period {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .timeline-role { font-size: 1.05rem; font-weight: 700; margin: 4px 0 2px; }
  .timeline-company { font-size: 0.85rem; color: var(--slate); margin-bottom: 8px; font-weight: 500; }
  .timeline-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .timeline-bullets li {
    font-size: 0.85rem;
    color: var(--slate-light);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }
  .timeline-bullets li::before {
    content: '•';
    position: absolute;
    left: 4px;
    color: var(--teal);
    font-weight: 700;
  }

  .skills-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .skill-category {
    background: var(--white);
    border-radius: var(--radius);
    padding: 20px;
    border: 1px solid var(--gray-200);
  }
  .skill-category-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--teal);
    margin-bottom: 12px;
  }
  .skill-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .skill-tag {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 4px 12px;
    background: var(--gray-100);
    color: var(--navy-light);
    border-radius: 20px;
    border: 1px solid var(--gray-200);
    transition: all 0.2s;
  }
  .skill-tag:hover {
    border-color: var(--teal);
    background: rgba(20, 184, 166, 0.05);
  }

  .achievement-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .achievement-list li {
    padding: 14px 16px 14px 44px;
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
    font-size: 0.9rem;
    position: relative;
  }
  .achievement-list li::before {
    content: '🏆';
    position: absolute;
    left: 14px;
    font-size: 1rem;
  }

  .edu-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 24px;
    border: 1px solid var(--gray-200);
  }
  .edu-card h3 { font-size: 1.05rem; font-weight: 700; }
  .edu-meta { font-size: 0.875rem; color: var(--slate); margin: 4px 0; }
  .edu-year { font-size: 0.8rem; color: var(--teal); font-weight: 600; }

  @media (max-width: 640px) {
    .page { padding: 100px 0 20px; }
    .page-title { font-size: 1.75rem; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
<style is:global>
  .hl-tech { color: #3b82f6; font-weight: 600; }
  .hl-ai { color: #8b5cf6; font-weight: 600; }
  .hl-metric { color: #f59e0b; font-weight: 700; }
</style>
