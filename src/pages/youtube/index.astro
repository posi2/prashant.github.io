---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Projects", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "YouTube", href: "/youtube" },
  { label: "Contact", href: "mailto:prashantchaturvedi2020@gmail.com" },
];
---

<Layout title="YouTube — Prashant Chaturvedi">
  <Nav items={navItems} />
  <main class="page">
    <div class="container">
      <h1 class="page-title">YouTube</h1>
      <p class="page-subtitle">Coding tutorials, tech talks, and project walkthroughs</p>

      <div class="channel-card">
        <div class="channel-info">
          <span class="channel-icon">📺</span>
          <div>
            <h2>Prashant Chaturvedi</h2>
            <p>Subscribe for programming tutorials and tech content</p>
          </div>
        </div>
        <a href="https://www.youtube.com/@prashantchaturvedi" target="_blank" rel="noopener" class="subscribe-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Subscribe
        </a>
      </div>

      <div class="empty-state">
        <span class="empty-icon">🎥</span>
        <h2>Content Coming Soon</h2>
        <p>I'm planning tutorials on machine learning, web development, and programming problem-solving. Subscribe to be notified when I upload.</p>
        <a href="/" class="back-link">← Back to Home</a>
      </div>

      <div class="video-placeholders">
        <div class="video-card">
          <div class="video-thumb placeholder">ML Tutorial</div>
          <div class="video-info">
            <h4>Coming soon</h4>
            <p>Machine Learning basics explained</p>
          </div>
        </div>
        <div class="video-card">
          <div class="video-thumb placeholder">Web Dev</div>
          <div class="video-info">
            <h4>Coming soon</h4>
            <p>Building modern websites with Astro</p>
          </div>
        </div>
        <div class="video-card">
          <div class="video-thumb placeholder">Coding</div>
          <div class="video-info">
            <h4>Coming soon</h4>
            <p>Competitive programming walkthroughs</p>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .page { padding: 120px 0 40px; min-height: 80vh; }
  .page-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; }
  .page-subtitle { color: var(--slate); font-size: 1.05rem; margin-bottom: 32px; }

  .channel-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: linear-gradient(135deg, #fef2f2, #fff);
    border: 1px solid #fecaca;
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .channel-info { display: flex; align-items: center; gap: 12px; }
  .channel-icon { font-size: 2rem; }
  .channel-info h2 { font-size: 1.1rem; font-weight: 700; }
  .channel-info p { font-size: 0.8rem; color: var(--slate); }
  .subscribe-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ef4444;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.2s;
  }
  .subscribe-btn:hover { background: #dc2626; }

  .empty-state {
    text-align: center;
    padding: 48px 20px;
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray-200);
    margin-bottom: 32px;
  }
  .empty-icon { font-size: 3rem; display: block; margin-bottom: 16px; }
  .empty-state h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 8px; }
  .empty-state p { color: var(--slate); max-width: 400px; margin: 0 auto 20px; font-size: 0.9rem; }
  .back-link { color: var(--teal); font-weight: 600; font-size: 0.9rem; }

  .video-placeholders { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .video-card {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--gray-200);
  }
  .video-thumb {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .video-thumb.placeholder {
    background: linear-gradient(135deg, var(--gray-100), var(--gray-200));
    color: var(--slate);
  }
  .video-info { padding: 12px 16px; }
  .video-info h4 { font-size: 0.9rem; font-weight: 600; }
  .video-info p { font-size: 0.8rem; color: var(--slate); }

  @media (max-width: 768px) {
    .video-placeholders { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .page-title { font-size: 1.75rem; }
  }
</style>
