---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Portfolio", href: "/portfolio" },
  { label: "Projects", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "YouTube", href: "/youtube" },
  { label: "Contact", href: "mailto:prashantchaturvedi2020@gmail.com" },
];

const projects = [
  {
    title: "Multi-Modal Review Moderation Platform",
    org: "G2",
    desc: "Built a scalable review moderation system combining <span class='hl-ai'>ML models</span>, rule engines, and agent workflows. Integrated <span class='hl-ai'>computer vision</span> for screenshot validation to verify real product usage.",
    tech: ["Python", "FastAPI", "Kubernetes", "ArgoCD", "Docker"],
    impact: "Increased moderation automation from 30% to 70%",
  },
  {
    title: "Enterprise RAG Pipeline",
    org: "G2",
    desc: "Designed a <span class='hl-ai'>RAG pipeline</span> using <span class='hl-tech'>Milvus</span> for vector storage with embeddings, semantic retrieval, reranking, and optimized chunking strategies.",
    tech: ["Python", "Milvus", "LangChain", "HuggingFace", "FastAPI"],
    impact: "Improved enterprise search relevance and response quality",
  },
  {
    title: "Image Moderation & Policy Detection",
    org: "G2",
    desc: "Implemented image moderation pipelines using <span class='hl-ai'>computer vision</span> models and product-aware validation to detect policy violations in user-submitted content.",
    tech: ["Python", "PyTorch", "OpenCV", "Kubernetes"],
    impact: "Reduced fraudulent submissions in moderation workflows",
  },
  {
    title: "Conversational AI for Pharma",
    org: "Tiger Analytics",
    desc: "Developed a <span class='hl-ai'>conversational AI</span> assistant for pharmaceutical experts, enabling efficient knowledge retrieval and domain-specific question answering using <span class='hl-tech'>Qdrant</span>-based <span class='hl-ai'>RAG</span>.",
    tech: ["Python", "Qdrant", "LangChain", "LLMs", "FastAPI"],
    impact: "Enabled domain-specific QA for pharmaceutical research",
  },
  {
    title: "LLM-Powered GenAI Workflows",
    org: "Tiger Analytics",
    desc: "Designed <span class='hl-ai'>LLM-powered</span> workflows with context-aware retrieval and structured outputs for enterprise-scale <span class='hl-ai'>GenAI</span> applications.",
    tech: ["Python", "LangChain", "LLMs", "REST APIs", "Docker"],
    impact: "Delivered structured GenAI solutions at enterprise scale",
  },
  {
    title: "Cancer Stage Prediction Pipeline",
    org: "Tiger Analytics",
    desc: "Led an end-to-end <span class='hl-ai'>ML pipeline</span> for cancer stage prediction using healthcare claims data with feature engineering and model selection.",
    tech: ["Python", "XGBoost", "Scikit-learn", "PySpark"],
    impact: "Achieved AUC of 85%",
  },
  {
    title: "Automated Question Generation (NLP)",
    org: "Tata Consultancy Services",
    desc: "Built an automated question generation system using <span class='hl-ai'>NLP</span> and deep learning for educational content creation. Applied POS tagging, embeddings, and fuzzy matching.",
    tech: ["Python", "NLP", "Deep Learning", "TensorFlow"],
    impact: "Reduced manual effort in educational content workflows",
  },
  {
    title: "Vehicle & Person Detection",
    org: "Codenscious",
    desc: "Managed a team under a vehicle and person detection project using <span class='hl-ai'>computer vision</span>, working directly under the CEO and delivering client software.",
    tech: ["Python", "Computer Vision", "Deep Learning"],
    impact: "Delivered client software with good profit margins",
  },
  {
    title: "Diabetes Classification",
    org: "Codenscious",
    desc: "Built a diabetes classification project spanning backend, frontend, classical AI, and <span class='hl-ai'>deep learning</span> with hands-on application of boosting algorithms.",
    tech: ["Python", "Scikit-learn", "Flask", "HTML/CSS"],
    impact: "Gained hands-on experience with production ML deployment",
  },
];
---

<Layout title="Projects — Prashant Chaturvedi">
  <Nav items={navItems} />
  <main class="page">
    <div class="container">
      <h1 class="page-title">Projects</h1>
      <p class="page-subtitle">Real-world ML & AI systems I've built across companies</p>

      <div class="projects-grid">
        {projects.map((p) => (
          <article class="project-card">
            <div class="card-header">
              <span class="card-org">{p.org}</span>
            </div>
            <h2 class="card-title" set:html={p.title}></h2>
            <p class="card-desc" set:html={p.desc}></p>
            <div class="card-tech">
              {p.tech.map((t) => <span class="tech-tag">{t}</span>)}
            </div>
            <div class="card-impact">
              <span class="impact-icon">📈</span>
              <span set:html={p.impact}></span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .page { padding: 120px 0 40px; }
  .page-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 8px; }
  .page-subtitle { color: var(--slate); font-size: 1.05rem; margin-bottom: 48px; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .project-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 28px;
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.25s;
  }
  .project-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: transparent;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .card-org {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--teal);
    background: rgba(20,184,166,0.08);
    padding: 3px 10px;
    border-radius: 6px;
  }

  .card-title { font-size: 1.1rem; font-weight: 700; line-height: 1.3; }
  .card-desc { font-size: 0.85rem; color: var(--slate); line-height: 1.6; flex: 1; }

  .card-tech { display: flex; gap: 6px; flex-wrap: wrap; }
  .tech-tag {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 10px;
    background: var(--gray-100);
    color: var(--navy-light);
    border-radius: 20px;
  }

  .card-impact {
    font-size: 0.83rem;
    font-weight: 600;
    color: var(--navy);
    background: linear-gradient(135deg, #fffbeb, #fff);
    border: 1px solid #fde68a;
    border-radius: 8px;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .impact-icon { font-size: 1rem; }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .page-title { font-size: 1.75rem; }
  }
</style>
<style is:global>
  .hl-tech { color: #3b82f6; font-weight: 600; }
  .hl-ai { color: #8b5cf6; font-weight: 600; }
  .hl-metric { color: #f59e0b; font-weight: 700; }
</style>
